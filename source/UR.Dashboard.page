Menu="Dashboard:90"
Cond="version_compare(parse_ini_file('/etc/unraid-version')['version'],'7.0.0','>=')"
---
<?php
/**
 * UR.Dashboard.page - a tile on Unraid's built-in DASHBOARD page.
 *
 * HOW THE DASHBOARD CONSUMES THIS (the contract, 6.12 - 7.3+):
 * Unraid renders the Dashboard from dynamix/DashStats.page (itself a
 * `Menu="Dashboard"` body). Plugin TILES are separate `Menu="Dashboard:<N>"`
 * bodies whose ONLY job is to populate the global `$mytiles[<slug>][<column>]`
 * string; DashStats then echoes each one server-side into the matching column's
 * `<table class="dashboard">` via its customTiles('columnN') calls. Because the
 * tile string is echoed server-side, the inline <style>/<script> below run
 * normally on page load. See dynamix/DashboardCustomTileExample.page- for the
 * reference implementation this mirrors.
 *
 * WHY THE HEADER MUST LOOK LIKE THIS (a 7.x regression we hit):
 *   - `Menu="Dashboard:<N>"`, NOT `Menu="Dashboard"`. A tile populator carries a
 *     position suffix so the framework includes it as a silent $mytiles
 *     contributor that runs BEFORE DashStats' customTiles() echo. With a bare
 *     `Menu="Dashboard"` (no suffix) the body sorted AFTER DashStats — so
 *     customTiles() ran with an empty $mytiles (tile missing) and our body was
 *     instead rendered as a standalone section, appended full-width at the very
 *     bottom of the page.
 *   - NO `Title=` (and no Icon/Tag). A `Title=` makes the framework wrap the body
 *     in its own titled page section — that is what produced the empty full-width
 *     "Rsync Backups" bar. The tile's visible title lives INSIDE the <tbody>
 *     (the canonical `tile-header` block), exactly like every built-in tile.
 *
 * The tile is read-only: it lists each job with a colored last-execution badge,
 * polling our existing read-only getStatus GET endpoint (no CSRF needed). It is a
 * normal sortable dashboard tile (the `title` attribute on the <tbody> is both
 * its Content-Manager description and its sortable key), so users show/hide it
 * and drag it to whatever position they like through the dashboard's own
 * controls; the chosen position is remembered per user.
 */

$slug = 'unraid.rsync';

$mytiles[$slug]['column1'] = <<<'HTML'
<tbody class="sortable" title="Rsync Backups">
  <tr><td>
    <span class="tile-header" id="ur-dash-header">
      <span class="tile-header-left">
        <img src="/plugins/unraid.rsync/unraid.rsync.png" alt="" class="f32" style="width:32px;height:32px;border-radius:6px;vertical-align:middle;">
        <div class="section">
          <h3 class="tile-header-main">Rsync Backups</h3>
          <span><span id="ur-dash-count">0</span> jobs</span>
        </div>
      </span>
      <span class="tile-header-right">
        <span class="tile-header-right-controls">
          <a href="/Settings/UnraidRsync" title="Open Unraid Rsync"><i class="fa fa-fw fa-cog control"></i></a>
        </span>
      </span>
    </span>
  </td></tr>
  <tr><td>
    <div id="ur-dash-body">
      <p style="font-style:italic;text-align:center;padding:8px 0;opacity:.7;">Loading…</p>
    </div>
  </td></tr>
</tbody>
<style>
  #ur-dash-body .ur-d-row { display:flex; align-items:center; gap:8px; padding:5px 2px; border-bottom:1px solid rgba(127,127,127,.18); }
  #ur-dash-body .ur-d-row:last-child { border-bottom:none; }
  #ur-dash-body .ur-d-name { flex:1 1 auto; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  #ur-dash-body .ur-d-badge { flex:0 0 auto; padding:1px 8px; border-radius:10px; font-size:.78rem; font-weight:bold; color:#fff; white-space:nowrap; }
  #ur-dash-body .ur-d-success { background:#1c7d3f; }
  #ur-dash-body .ur-d-warning { background:#b15c00; color:#1a1a1a; }
  #ur-dash-body .ur-d-failed  { background:#b71c1c; }
  #ur-dash-body .ur-d-aborted { background:#555; }
  #ur-dash-body .ur-d-pending { background:#777; }
  #ur-dash-body .ur-d-running { background:#1565c0; }
</style>
<script>
(function () {
  'use strict';
  var URL = '/plugins/unraid.rsync/include/handler.php?action=getStatus';
  function cls(state, running) {
    if (running) { return 'ur-d-running'; }
    switch ((state || '').toUpperCase()) {
      case 'SUCCESS': return 'ur-d-success';
      case 'WARNING': case 'PARTIAL': return 'ur-d-warning';
      case 'FAILED': case 'TIMEOUT': return 'ur-d-failed';
      case 'ABORTED': return 'ur-d-aborted';
      default: return 'ur-d-pending';
    }
  }
  function esc(t) { var d = document.createElement('div'); d.textContent = (t == null ? '' : t); return d.innerHTML; }
  function render(jobs) {
    var body = document.getElementById('ur-dash-body');
    var count = document.getElementById('ur-dash-count');
    if (!body) { return; }
    var ids = Object.keys(jobs || {});
    if (count) { count.textContent = ids.length; }
    if (!ids.length) {
      body.innerHTML = '<p style="font-style:italic;text-align:center;padding:8px 0;opacity:.7;">No jobs configured</p>';
      return false;
    }
    var anyRunning = false;
    var html = ids.map(function (id) {
      var j = jobs[id];
      if (j.running) { anyRunning = true; }
      var label = j.running ? 'Running' : ((j.state || 'pending').charAt(0) + (j.state || 'pending').slice(1).toLowerCase());
      return '<div class="ur-d-row"><span class="ur-d-name">' + esc(j.name) +
             '</span><span class="ur-d-badge ' + cls(j.state, j.running) + '">' + esc(label) + '</span></div>';
    }).join('');
    body.innerHTML = html;
    return anyRunning;
  }
  var timer = null;
  function poll() {
    fetch(URL, { credentials: 'same-origin', cache: 'no-store' })
      .then(function (r) { return r.json(); })
      .then(function (d) { return render((d && d.jobs) || {}); })
      .catch(function () { return false; })
      .then(function (anyRunning) {
        if (timer) { clearTimeout(timer); }
        timer = setTimeout(poll, anyRunning ? 3000 : 20000);
      });
  }
  if (document.readyState !== 'loading') { poll(); }
  else { document.addEventListener('DOMContentLoaded', poll); }
})();
</script>
HTML;
?>
