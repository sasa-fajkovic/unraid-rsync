# Build output: the versioned .txz packages are attached to GitHub Releases,
# never committed to the repo.
/archive/

# Build temp dirs / staging
/tmp/
*.tmp

# OS / editor cruft
.DS_Store
*.swp

# Sublime SFTP config sometimes used when sideloading to a live Unraid box
sftp-config.json

# PHP / PHPUnit (vendor + caches are not committed; composer.lock IS committed
# - this is a "type: project", so the lock pins the exact dev toolchain for
# reproducible CI test runs + integrity-verified installs).
/vendor/
/.phpunit.cache/
.phpunit.result.cache
