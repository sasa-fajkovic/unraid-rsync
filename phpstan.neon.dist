# PHPStan static analysis, scoped to the backend that matters most: the
# proc_open/ssh/rsync shell-out classes and the CLI scripts. The webGui page
# bodies (source/pages, *.page) are intentionally NOT analysed - they lean on
# webGui globals ($GLOBALS['var'], the _() translation fn, included var.ini)
# that only exist inside the live dynamix runtime, so they would produce only
# environment noise here.
#
# treatPhpDocTypesAsCertain is OFF: this code DELIBERATELY re-validates values
# whose PHPDoc type is not guaranteed at runtime (JSON-decoded config.json /
# credentials.json, proc_get_status() arrays, etc.). Trusting the PHPDoc would
# flag those defensive checks as "always true" and pressure us to delete the
# very guards that make the plugin robust against malformed on-disk state.
#
# A baseline (phpstan-baseline.neon) absorbs the remaining pre-existing,
# intentional findings so this gate catches NEW regressions from here on.
#
# Level 6 (raised from 5): adds missing-type-hint enforcement; every finding was
# fixed with a real type annotation (no new baseline entries). Level 7 is NOT
# used on purpose: its remaining findings are almost entirely offsetAccess on the
# deliberate "discriminated array shape" results (e.g. {ok:bool, error?:string,
# token?:string}) that this code guards at runtime by checking `ok` first.
# Encoding that precisely isn't expressible for PHP arrays, so level 7 would
# force either hollow suppressions or rewriting working defensive code - neither
# is a quality win. Revisit if those results ever become value objects.
includes:
    - phpstan-baseline.neon

parameters:
    level: 6
    paths:
        - source/include
        - source/scripts
    treatPhpDocTypesAsCertain: false
