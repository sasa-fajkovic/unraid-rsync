{
    "name": "sasa-fajkovic/unraid-rsync",
    "description": "Native Unraid webGui plugin for scheduling and monitoring rsync backup jobs.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "test": "phpunit",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "stan": "phpstan analyse --memory-limit=1G"
    },
    "config": {
        "platform": {
            "php": "8.4.21"
        }
    }
}
