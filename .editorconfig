# EditorConfig - consistent whitespace across editors. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markup/config conventionally use 2-space indent.
[*.{yml,yaml,json,md}]
indent_size = 2

# Markdown: trailing spaces are a hard line break, so don't trim them.
[*.md]
trim_trailing_whitespace = false

# The .plg is XML; keep it 2-space like the other markup.
[*.plg]
indent_size = 2

# Makefiles (if any) require real tabs.
[Makefile]
indent_style = tab
