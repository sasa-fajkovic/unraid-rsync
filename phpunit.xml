<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/13.2/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         failOnWarning="true"
         failOnRisky="true">
    <testsuites>
        <testsuite name="unraid-rsync">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
    <!-- Coverage scope = the unit-tested backend (matches the PHPStan and
         php-cs-fixer scope). The mixed HTML/PHP page bodies aren't unit-tested, so
         including them would only depress the number with untestable view code.
         Coverage is reported in CI (pcov, via the phpunit coverage-text flag); a
         local `composer test` needs no driver. -->
    <source>
        <include>
            <directory>source/include</directory>
            <directory>source/scripts</directory>
        </include>
    </source>
</phpunit>
